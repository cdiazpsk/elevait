{
  "expo": {
    "name": "ELEVaiT",
    "slug": "elevait",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "elevait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elevait.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ELEVaiT needs your location to track vendor arrivals at buildings.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ELEVaiT needs background location access for geofence-based check-in/check-out at buildings.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B4F72"
      },
      "package": "com.elevait.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      "expo-secure-store",
      [
        "expo-barcode-scanner",
        { "cameraPermission": "ELEVaiT needs camera access to scan equipment QR codes." }
      ]
    ]
  }
}
